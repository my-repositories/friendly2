{
  "manifest_version": 3,
  "name": "friendly2",
  "short_name": "friendly2",
  "version": "2.1.0",
  "description": "Google Chrome extension which automates sending requests to friends/subscribers.",
  "author": "Aleksandr Loktionov <loktionov129@gmail.com>",
  "homepage_url": "https://github.com/my-repositories/friendly2",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_title": "friendly2",
    "default_popup": "popup/index.html"
  },
  "options_page": "options/index.html",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage", "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["https://likes.fm/*"],
      "js": ["sites/likes_fm.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://career.habr.com/*"],
      "js": ["sites/habr_career.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://github.com/*"],
      "js": ["sites/github.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://vk.com/*"],
      "js": ["sites/vk_com.js"],
      "run_at": "document_idle"
    }
  ]
}
